---
import { ClientRouter, slide } from 'astro:transitions'
import Logo from '@assets/logo.svg'
interface Link {
  href: string
  label: string
}

const links = [
  {
    href: '/zyciorys',
    label: 'Życiorys',
  },
  {
    href: '/blog',
    label: 'Blog',
  },
  {
    href: '/o-witrynie',
    label: 'O witrynie',
  },
  {
    href: '/kontakt',
    label: 'Kontakt',
  },
] as const satisfies Link[]

type hrefs = (typeof links)[number]['href']

interface Props {
  parentHref?: hrefs
}

const { parentHref } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <ClientRouter />
  </head>
  <body flex flex-col min-h-screen>
    <nav p="x-4 y-4" md:p="x-16 y-4" border-b="1px solid #ccc" bg-white>
      <div flex flex-row gap="2" items-center justify-between>
        <a href="/">
          <Logo width={48} />
        </a>

        <div flex flex-row gap="16" class="hidden md:flex">
          {
            links.map((el) => (
              <a
                hover:border-b="2px solid slate-700"
                border-b={
                  el.href === parentHref
                    ? '2px solid black'
                    : '2px solid transparent'
                }
                text="black!"
                class="decoration-none!"
                href={el.href}
              >
                {el.label}
              </a>
            ))
          }
        </div>

        <button
          id="menu-toggle"
          flex="~ col"
          gap-1.5
          p-2
          class="md:hidden"
          aria-label="Menu"
        >
          <span block w-6 h-0.5 bg-black></span>
          <span block w-6 h-0.5 bg-black></span>
          <span block w-6 h-0.5 bg-black></span>
        </button>
      </div>
    </nav>

    <div
      id="menu-overlay"
      class="fixed inset-0 z-40 transition-opacity duration-300 pointer-events-none bg-black/50 op-0 data-[open]:op-100 data-[open]:pointer-events-auto ease"
    >
    </div>
    <div
      id="mobile-menu"
      class="fixed top-0 right-0 z-50 p-6 w-64 h-full bg-white shadow-lg transition-transform duration-300 translate-x-full data-[open]:translate-x-0 ease"
    >
      <button
        id="menu-close"
        absolute
        top-4
        right-4
        text-2xl
        aria-label="Close menu">&times;</button
      >
      <nav flex flex-col gap-6 mt-8 transition:persist>
        {
          links.map((el) => (
            <a
              hover:border-b="2px solid slate-700"
              border-b={
                el.href === parentHref
                  ? '2px solid black'
                  : '2px solid transparent'
              }
              href={el.href}
              text-lg
              text="black!"
              class="decoration-none! mobile-link"
            >
              {el.label}
            </a>
          ))
        }
      </nav>
    </div>

    <script>
      const setupMenu = () => {
        const toggle = document.querySelector('#menu-toggle')
        const close = document.querySelector('#menu-close')
        const menu = document.querySelector('#mobile-menu')
        const overlay = document.querySelector('#menu-overlay')
        const links = document.querySelectorAll('.mobile-link')

        const openMenu = () => {
          menu?.setAttribute('data-open', '')
          overlay?.setAttribute('data-open', '')
        }

        const closeMenu = () => {
          menu?.removeAttribute('data-open')
          overlay?.removeAttribute('data-open')
        }

        toggle?.addEventListener('click', openMenu)
        close?.addEventListener('click', closeMenu)
        overlay?.addEventListener('click', closeMenu)
        links.forEach((link) => link.addEventListener('click', closeMenu))
      }

      setupMenu()

      document.addEventListener('astro:after-swap', () => {
        window.scrollTo({ left: 0, top: 0, behavior: 'instant' })
        setupMenu()
      })
    </script>

    <main
      flex-1
      mb-4
      px-4
      container
      mx-auto
      mt-12
      transition:animate={slide({ duration: '0.5s' })}
    >
      <slot />
    </main>
    <footer w-full border-t="1px solid black" text-sm px-4 py-2>
      © {new Date().getFullYear()} Szymon Wrzos • Zbudowano w Astro. Więcej o stronie
      {' '}
      <a
        link:text-blue-500
        visited:text-purple-500
        hover-visited:border-b="2px solid purple-500"
        hover:border-b="2px solid blue-500"
        border-b="2px solid transparent"
        href="/o-witrynie"
      >
        tutaj
      </a>
    </footer>
  </body>
</html>

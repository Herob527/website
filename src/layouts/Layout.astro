---
import { ClientRouter, slide } from 'astro:transitions'
import Logo from '@assets/logo.svg'
import Link from '@components/Link.astro'
import '../styles/global.css'
interface LinkItem {
  href: string
  label: string
}

const links = [
  {
    href: '/zyciorys',
    label: 'Życiorys',
  },
  {
    href: '/blog',
    label: 'Blog',
  },
  {
    href: '/o-witrynie',
    label: 'O witrynie',
  },
  {
    href: '/kontakt',
    label: 'Kontakt',
  },
] as const satisfies LinkItem[]

type hrefs = (typeof links)[number]['href']

interface Props {
  parentHref?: hrefs
}

const { parentHref } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}/favicon.svg`}
    />
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen">
    <nav class="px-4 py-4 md:px-16 md:py-4 border-b border-solid border-[#ccc] bg-white">
      <div class="flex flex-row gap-2 items-center justify-between">
        <Link href="/">
          <Logo width={48} />
        </Link>

        <div class="flex flex-row gap-16 hidden md:flex">
          {
            links.map((el) => (
              <Link
                class:list={[
                  'text-black!',
                  'decoration-none!',
                  'hover:border-b-2 hover:border-solid hover:border-slate-700',
                  {
                    'border-b-2 border-solid border-black':
                      el.href === parentHref,
                    'border-b-2 border-solid border-transparent':
                      el.href !== parentHref,
                  },
                ]}
                href={el.href}
              >
                {el.label}
              </Link>
            ))
          }
        </div>

        <button
          id="menu-toggle"
          class="flex flex-col gap-1.5 p-2 md:hidden"
          aria-label="Menu"
        >
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
        </button>
      </div>
    </nav>

    <div
      id="menu-overlay"
      class="fixed inset-0 z-40 transition-opacity duration-300 pointer-events-none bg-black/50 opacity-0 data-[open]:opacity-100 data-[open]:pointer-events-auto ease"
    >
    </div>
    <div
      id="mobile-menu"
      class="fixed top-0 right-0 z-50 p-6 w-64 h-full bg-white shadow-lg transition-transform duration-300 translate-x-full data-[open]:translate-x-0 ease"
    >
      <button
        id="menu-close"
        class="absolute top-4 right-4 text-2xl"
        aria-label="Close menu">&times;</button
      >
      <nav class="flex flex-col gap-6 mt-8" transition:persist>
        {
          links.map((el) => (
            <Link
              class:list={[
                'text-lg',
                'text-black!',
                'decoration-none!',
                'mobile-link',
                'hover:border-b-2',
                'hover:border-solid',
                'hover:border-slate-700',
                {
                  'border-b-2 border-solid border-black':
                    el.href === parentHref,
                  'border-b-2 border-solid border-transparent':
                    el.href !== parentHref,
                },
              ]}
              href={el.href}
            >
              {el.label}
            </Link>
          ))
        }
      </nav>
    </div>

    <script>
      const setupMenu = () => {
        const toggle = document.querySelector('#menu-toggle')
        const close = document.querySelector('#menu-close')
        const menu = document.querySelector('#mobile-menu')
        const overlay = document.querySelector('#menu-overlay')
        const links = document.querySelectorAll('.mobile-link')

        const openMenu = () => {
          menu?.setAttribute('data-open', '')
          overlay?.setAttribute('data-open', '')
        }

        const closeMenu = () => {
          menu?.removeAttribute('data-open')
          overlay?.removeAttribute('data-open')
        }

        toggle?.addEventListener('click', openMenu)
        close?.addEventListener('click', closeMenu)
        overlay?.addEventListener('click', closeMenu)
        links.forEach((link) => link.addEventListener('click', closeMenu))
      }

      setupMenu()

      document.addEventListener('astro:after-swap', () => {
        window.scrollTo({ left: 0, top: 0, behavior: 'instant' })
        setupMenu()
      })
    </script>

    <main
      class="flex-1 mb-4 px-4 container mx-auto mt-12"
      transition:animate={slide({ duration: '0.5s' })}
    >
      <slot />
    </main>
    <footer class="w-full border-t border-solid border-black text-sm px-4 py-2">
      © {new Date().getFullYear()} Szymon Wrzos • Zbudowano w Astro. Więcej o stronie
      {' '}
      <Link
        class="text-blue-500 border-b-2 border-transparent border-solid visited:text-purple-500 hover:border-b-2 hover:border-blue-500 hover:border-solid hover:visited:border-b-2 hover:visited:border-solid hover:visited:border-purple-500"
        href="/o-witrynie"
      >
        tutaj
      </Link>
    </footer>
  </body>
</html>

---
import { ClientRouter, slide } from 'astro:transitions'
import Logo from '../assets/logo.svg'
interface Link {
  href: string
  label: string
}

const links = [
  {
    href: '/zyciorys',
    label: 'Życiorys',
  },
  {
    href: '#',
    label: 'Blog',
  },
  {
    href: '/o-witrynie',
    label: 'O witrynie',
  },
  {
    href: '/kontakt',
    label: 'Kontakt',
  },
] as const satisfies Link[]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <ClientRouter transition:animate={slide({ duration: '0.4s' })} />
  </head>
  <body>
    <nav px="16" py="4" border-b="1px solid #ccc" bg-white>
      <div flex flex-row gap="2" items-center justify-between>
        <a href="/">
          <Logo width={48} />
        </a>

        <div flex flex-row gap="16" class="hidden md:flex">
          {
            links.map((el) => (
              <a
                hover:border-b="2px solid #000"
                border-b="2px solid transparent"
                text="black!"
                class="decoration-none!"
                href={el.href}
              >
                {el.label}
              </a>
            ))
          }
        </div>

        <button
          id="menu-toggle"
          class="flex flex-col gap-1.5 p-2 md:hidden"
          aria-label="Menu"
        >
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
        </button>
      </div>
    </nav>

    <div
      id="menu-overlay"
      class="fixed inset-0 z-40 transition-opacity duration-300 pointer-events-none bg-black/50 op-0 data-[open]:op-100 data-[open]:pointer-events-auto ease"
    >
    </div>
    <div
      id="mobile-menu"
      class="fixed top-0 right-0 z-50 p-6 w-64 h-full bg-white shadow-lg transition-transform duration-300 translate-x-full data-[open]:translate-x-0 ease"
    >
      <button
        id="menu-close"
        class="absolute top-4 right-4 text-2xl"
        aria-label="Close menu">&times;</button
      >
      <nav flex flex-col gap-6 mt-8 transition:persist>
        {
          links.map((el) => (
            <a
              hover:border-b="2px solid #000"
              border-b="2px solid transparent"
              href={el.href}
              text-lg
              class="text-lg mobile-link"
            >
              {el.label}
            </a>
          ))
        }
      </nav>
    </div>

    <script>
      const setupMenu = () => {
        const toggle = document.getElementById('menu-toggle')
        const close = document.getElementById('menu-close')
        const menu = document.getElementById('mobile-menu')
        const overlay = document.getElementById('menu-overlay')
        const links = document.querySelectorAll('.mobile-link')

        const openMenu = () => {
          menu?.setAttribute('data-open', '')
          overlay?.setAttribute('data-open', '')
        }

        const closeMenu = () => {
          menu?.removeAttribute('data-open')
          overlay?.removeAttribute('data-open')
        }

        toggle?.addEventListener('click', openMenu)
        close?.addEventListener('click', closeMenu)
        overlay?.addEventListener('click', closeMenu)
        links.forEach((link) => link.addEventListener('click', closeMenu))
      }

      setupMenu()

      document.addEventListener('astro:after-swap', () => {
        window.scrollTo({ left: 0, top: 0, behavior: 'instant' })
        setupMenu()
      })
    </script>

    <main mb-4 px-4 container mx-auto mt-12>
      <slot />
    </main>
  </body>
</html>

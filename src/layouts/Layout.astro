---
import { ClientRouter, slide } from 'astro:transitions'
import Logo from '@assets/logo.svg'
import Link from '@components/Link.astro'
import LanguageSwitcher from '@components/LanguageSwitcher.astro'
import '../styles/global.css'
const { t } = Astro.locals

interface LinkItem {
  href: string
  label: string
}

const links = [
  {
    href: '/zyciorys',
    label: t('nav.cv'),
  },
  {
    href: '/blog',
    label: t('nav.blog'),
  },
  {
    href: '/o-witrynie',
    label: t('nav.about'),
  },
  {
    href: '/kontakt',
    label: t('nav.contact'),
  },
] as const satisfies LinkItem[]

type hrefs = (typeof links)[number]['href']

interface Props {
  parentHref?: hrefs
  title?: string
}

const { parentHref, title } = Astro.props
---

<html lang={Astro.currentLocale}>
  <head>
    <meta charset="utf-8" />
    <title>{title ?? 'Astro'}</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}/favicon.svg`.replace('//', '/')}
    />
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}/favicon.ico`.replace('//', '/')}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen">
    <nav
      class="py-4 px-4 bg-white border-b border-solid md:py-4 md:px-16 border-[#ccc]"
    >
      <div class="flex flex-row gap-2 justify-between items-center">
        <Link href="/">
          <Logo height={40} />
        </Link>

        <div class="hidden flex-row gap-8 items-center md:flex">
          {
            links.map((el) => (
              <Link
                class:list={[
                  'text-black! decoration-none!',
                  'hover:border-b-2 hover:border-solid hover:border-slate-700',
                  {
                    'border-b-2 border-solid border-black':
                      el.href === parentHref,
                    'border-b-2 border-solid border-transparent':
                      el.href !== parentHref,
                  },
                ]}
                href={el.href}
              >
                {el.label}
              </Link>
            ))
          }
          <span class="text-gray-300">|</span>
          <LanguageSwitcher />
        </div>

        <button
          id="menu-toggle"
          class="flex flex-col gap-1.5 p-2 md:hidden"
          aria-label="Menu"
        >
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
          <span class="block w-6 h-0.5 bg-black"></span>
        </button>
      </div>
    </nav>

    <div
      id="menu-overlay"
      class="fixed inset-0 z-40 opacity-0 transition-opacity duration-300 pointer-events-none bg-black/50 data-open:opacity-100 data-open:pointer-events-auto ease"
    >
    </div>
    <div
      id="mobile-menu"
      class="fixed top-0 right-0 z-50 p-6 w-64 h-full bg-white shadow-lg transition-transform duration-300 translate-x-full data-open:translate-x-0 ease"
    >
      <button
        id="menu-close"
        class="absolute top-4 right-4 text-2xl"
        aria-label="Close menu">&times;</button
      >
      <nav class="flex flex-col gap-6 mt-8">
        {
          links.map((el) => (
            <Link
              class:list={[
                'text-lg text-black! decoration-none!',
                'mobile-link',
                'hover:border-b-2 hover:border-solid hover:border-slate-700',
                {
                  'border-b-2 border-solid border-black':
                    el.href === parentHref,
                  'border-b-2 border-solid border-transparent':
                    el.href !== parentHref,
                },
              ]}
              href={el.href}
            >
              {el.label}
            </Link>
          ))
        }
        <hr class="border-gray-300" />
        <LanguageSwitcher />
      </nav>
    </div>

    <script>
      import { viewTransitionCallback } from '../utils'

      const setupMenu = () => {
        const toggle = document.querySelector('#menu-toggle')
        const close = document.querySelector('#menu-close')
        const menu = document.querySelector('#mobile-menu')
        const overlay = document.querySelector('#menu-overlay')
        const links = document.querySelectorAll('.mobile-link')

        const openMenu = () => {
          menu?.setAttribute('data-open', '')
          overlay?.setAttribute('data-open', '')
        }

        const closeMenu = () => {
          menu?.removeAttribute('data-open')
          overlay?.removeAttribute('data-open')
        }

        toggle?.addEventListener('click', openMenu)
        close?.addEventListener('click', closeMenu)
        overlay?.addEventListener('click', closeMenu)
        links.forEach((link) => link.addEventListener('click', closeMenu))
      }

      viewTransitionCallback(() => {
        window.scrollTo({ left: 0, top: 0, behavior: 'instant' })
        setupMenu()
      })
    </script>

    <main
      class="container flex-1 px-4 mx-auto mt-12 mb-4"
      transition:animate={slide({ duration: '0.5s' })}
    >
      <slot />
    </main>
    <footer class="py-2 px-4 w-full text-sm border-t border-black border-solid">
      © {new Date().getFullYear()} Szymon Wrzos • {t('footer.builtIn')}
      {' '}
      <Link
        class="text-blue-500 border-b-2 border-transparent border-solid visited:text-purple-500 hover:border-b-2 hover:border-blue-500 hover:border-solid hover:visited:border-b-2 hover:visited:border-solid hover:visited:border-purple-500"
        href="/o-witrynie"
      >
        {t('footer.here')}
      </Link>
    </footer>
  </body>
</html>

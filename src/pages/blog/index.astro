---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
  )
  .map((post) => ({
    ...post,
    formattedDate: new Intl.DateTimeFormat('pl-PL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(post.data.date)),
  }))
---

<Layout parentHref="/blog">
  <section max-w-2xl mx-auto>
    <header mb-10>
      <h1 text-center text-4xl font-semibold>Blog</h1>
    </header>

    <ul flex flex-col gap-6>
      {
        posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              block
              class="p-6 bg-gray-100 rounded-lg duration-300 hover:bg-gray-200 transition-[background-color]"
            >
              <time text-sm text-gray-500>
                {post.formattedDate}
              </time>
              <h2 text-xl font-medium mt-1 mb-2>
                {post.data.title}
              </h2>
              <p text-gray-600 text-sm>
                {post.data.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

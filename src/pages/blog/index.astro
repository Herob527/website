---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
)
---

<Layout>
  <section max-w-2xl mx-auto>
    <header mb-10>
      <h1 text-center text-4xl font-semibold>Blog</h1>
    </header>

    <ul flex flex-col gap-6>
      {
        posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              block
              border="1px solid #e5e7eb"
              rounded-lg
              p-6
              no-underline
              transition="border-color 0.2s"
              hover:border-gray-400
            >
              <time text-sm text-gray-500>{post.data.date}</time>
              <h2 text-xl font-medium mt-1 mb-2>{post.data.title}</h2>
              <p text-gray-600 text-sm>{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

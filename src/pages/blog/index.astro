---
import Layout from '@layouts/Layout.astro'
import Link from '@components/Link.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
  )
  .map((post) => ({
    ...post,
    formattedDate: new Intl.DateTimeFormat('pl-PL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(post.data.date)),
  }))
---

<Layout parentHref="/blog">
  <section class="max-w-2xl mx-auto">
    <header class="mb-10">
      <h1 class="text-center text-4xl font-semibold">Blog</h1>
    </header>

    <ul class="flex flex-col gap-6">
      {
        posts.map((post) => (
          <li>
            <Link
              href={`/blog/${post.id}`}
              class="block p-6 bg-gray-100 rounded-lg duration-300 hover:bg-gray-200 transition-[background-color]"
            >
              <time class="text-sm text-gray-500">
                {post.formattedDate}
              </time>
              <h2 class="text-xl font-medium mt-1 mb-2">
                {post.data.title}
              </h2>
              <p class="text-gray-600 text-sm">
                {post.data.description}
              </p>
            </Link>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

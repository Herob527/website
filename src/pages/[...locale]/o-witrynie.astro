---
import Layout from '@layouts/Layout.astro'
import eslintConfig from '@root/eslint.config?raw'
import prettierConfig from '@root/.prettierrc?raw'
import tsconfig from '@root/tsconfig.json?raw'
import packageJson from '@root/package.json?raw'
import astroConfig from '@root/astro.config.mjs?raw'
import mise from '@root/mise.toml?raw'
import globalCss from '@root/src/styles/global.css?raw'
import type { CodeLanguage, GetStaticPaths } from 'astro'
import { Code } from 'astro:components'
import { geti18nStaticPaths } from '@root/src/i18n'

const { t } = Astro.locals

interface StackItem {
  type: string
  name: string
  href: string
}

const stack = [
  {
    type: t('aboutPage.stack.framework'),
    name: 'Astro (SSG)',
    href: 'https://astro.build/',
  },
  {
    type: t('aboutPage.stack.styleEngine'),
    name: 'Tailwind CSS',
    href: 'https://tailwindcss.com/',
  },
  {
    type: t('aboutPage.stack.scripts'),
    name: 'TypeScript',
    href: 'https://www.typescriptlang.org/',
  },
  {
    type: t('aboutPage.stack.packageManager'),
    name: 'Bun',
    href: 'https://bun.com/',
  },
  {
    type: t('aboutPage.stack.linter'),
    name: 'ESLint',
    href: 'https://eslint.org/',
  },
  {
    type: t('aboutPage.stack.formatter'),
    name: 'Prettier',
    href: 'https://prettier.io/',
  },
  {
    type: t('aboutPage.stack.aiEditor'),
    name: 'Opencode (MiMo V2.5 Free)',
    href: 'https://opencode.ai/',
  },
] as const satisfies StackItem[]

interface ConfigItem {
  name: string
  code: string
  type: CodeLanguage
}

const configs = [
  {
    name: 'astro.config.mjs',
    code: astroConfig,
    type: 'js',
  },
  {
    name: 'eslint.config.js',
    code: eslintConfig,
    type: 'ts',
  },
  {
    name: '.prettierrc',
    code: prettierConfig,
    type: 'json',
  },
  {
    name: 'tsconfig.json',
    code: tsconfig,
    type: 'jsonc',
  },
  {
    name: 'package.json',
    code: packageJson,
    type: 'json',
  },
  {
    name: 'src/styles/global.css',
    code: globalCss,
    type: 'css',
  },
  {
    name: 'mise.toml',
    code: mise,
    type: 'toml',
  },
] as const satisfies ConfigItem[]

export const getStaticPaths = (() => {
  return geti18nStaticPaths()
}) satisfies GetStaticPaths
---

<Layout parentHref="/o-witrynie" title={t('aboutPage.title')}>
  <section>
    <header class="mb-6 text-center text-4xl font-semibold">
      <h1>{t('aboutPage.title')}</h1>
    </header>
    <article>
      <header class="mb-4 text-2xl">
        <h2>{t('aboutPage.techStack')}</h2>
      </header>
      <table>
        {
          stack.map((item) => (
            <tr>
              <td class="py-1 pr-4">{item.type}:</td>
              <td>
                <a
                  class="border-b-2 border-solid border-transparent text-blue-500 visited:text-purple-500 hover:border-b-2 hover:border-solid hover:border-blue-500 hover:visited:border-b-2 hover:visited:border-solid hover:visited:border-purple-500"
                  href={item.href}
                  target="_blank"
                >
                  {item.name}
                </a>
              </td>
            </tr>
          ))
        }
      </table>
    </article>
    <article class="mt-4">
      <header class="mb-4 text-2xl">
        <h2>{t('aboutPage.configs')}</h2>
      </header>
      <div class="flex flex-col gap-2">
        {
          configs.map((item) => (
            <div class="min-h-0 overflow-hidden">
              <input
                type="checkbox"
                id={`toggle-${item.name}`}
                hidden
                class="peer"
              />
              <label
                for={`toggle-${item.name}`}
                class="flex flex-row items-center border-2 border-black"
              >
                <p class="flex-1 border-r-2 border-black p-2">{item.name}</p>
                <span class="rotate-90 p-2 px-4 transition-transform">
                  &rangle;
                </span>
              </label>

              <div class="grid grid-rows-[0fr] overflow-y-hidden transition-[grid-template-rows] duration-400 ease-in-out peer-checked:grid-rows-[1fr]">
                <div class="min-h-0">
                  <Code
                    class="p-4"
                    data-name={item.name}
                    code={item.code}
                    lang={item.type}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </article>
  </section>
</Layout>

<style>
  input.peer:checked + label > span {
    scale: -1 -1;
  }
</style>

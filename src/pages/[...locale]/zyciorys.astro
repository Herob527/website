---
import Layout from '@layouts/Layout.astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import type { AstroComponentFactory } from 'astro/runtime/server/render/astro/factory.js'
import { geti18nStaticPaths } from '@root/src/i18n'
import type { GetStaticPaths } from 'astro'
import { DEFAULT_LANGUAGE } from '@root/src/constants'
import { dateUtils } from '@root/src/date-utils'

type LifeStageEntry = CollectionEntry<'lifeStages'>

interface IncludedStage {
  entry: LifeStageEntry
  Content: AstroComponentFactory
}

interface StageWithContent {
  entry: LifeStageEntry
  Content: AstroComponentFactory
  included: IncludedStage[]
}

const locale = Astro.currentLocale ?? DEFAULT_LANGUAGE

const allStages = await getCollection('lifeStages')

const localeStages = allStages.filter((s) => s.id.startsWith(`${locale}/`))

const parents = localeStages
  .filter((s) => !s.data.parent)
  .sort((a, b) => a.data.order - b.data.order)

const children = localeStages
  .filter((s) => s.data.parent)
  .sort((a, b) => a.data.order - b.data.order)

const stripLocale = (id: string) => id.replace(/^[a-z]{2}\//, '')

const stagesWithContent = await Promise.all(
  parents.map(async (parent) => {
    const { Content } = await render(parent)
    const included = await Promise.all(
      children
        .filter((c) => c.data.parent === stripLocale(parent.id))
        .map(async (c) => {
          const { Content: IncContent } = await render(c)
          return { entry: c, Content: IncContent }
        }),
    )
    return { entry: parent, Content, included }
  }),
)

const { t } = Astro.locals
const months = t('cvPage.months', { returnObjects: true }) as string[]

const formatDate = (date: Temporal.PlainDate) => {
  return `${months[date.month - 1]} ${date.year.toString()}`
}

const sorted = stagesWithContent
  .map((s: StageWithContent) => ({
    ...s,
    startDate: dateUtils.parse(s.entry.data.startDate),
    endDate: dateUtils.parse(s.entry.data.endDate),
    color: s.entry.data.color,
  }))
  .sort((a, b) => dateUtils.compare(a.startDate, b.startDate))

export const getStaticPaths = (() => {
  return geti18nStaticPaths()
}) satisfies GetStaticPaths
---

<Layout parentHref="/zyciorys" title={t('cvPage.title')}>
  <section>
    <header class="mb-6 text-4xl font-semibold text-center">
      <h1>{t('cvPage.title')}</h1>
    </header>

    <div class="mx-auto w-full md:px-4 max-w-[900px]">
      <div class="relative border-l-2 border-solid md:ml-6 border-[#e5e7eb]">
        {
          sorted.map((stage) => (
            <div class="pl-4 mb-12 md:pl-8">
              <span class="text-sm font-semibold tabular-nums text-gray-400">
                {formatDate(stage.startDate)} — {formatDate(stage.endDate)}
              </span>

              <div
                class="p-3 mt-2 bg-white shadow-sm"
                style={`border-left: 3px solid ${stage.color}`}
              >
                <span class="text-sm font-semibold text-gray-800">
                  {stage.entry.data.label}
                </span>
                <div
                  class="mt-1 text-sm leading-relaxed text-gray-600 timeline-content prose"
                  style=""
                >
                  <stage.Content />
                </div>
                {stage.included.map((inc: IncludedStage) => (
                  <div
                    class="p-2 mt-2"
                    style={`background: rgba(245,245,245,0.9); border-left: 2px solid ${stage.color}`}
                  >
                    <span class="text-sm font-medium text-gray-700">
                      {inc.entry.data.label}
                    </span>
                    <span class="block text-sm tabular-nums text-gray-500">
                      {inc.entry.data.startDate} — {inc.entry.data.endDate}
                    </span>
                    <div class="mt-1 text-sm leading-relaxed text-gray-600 prose">
                      <inc.Content />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro'

const stack = [
  { type: 'Framework', name: 'Astro', href: 'https://astro.build/' },
  { type: 'Silnik styli', name: 'UnoCSS', href: 'https://unocss.dev/' },
  {
    type: 'Skrypty',
    name: 'TypeScript',
    href: 'https://www.typescriptlang.org/',
  },
  { type: 'Linter', name: 'ESLint', href: 'https://eslint.org/' },
  { type: 'Formatter', name: 'Prettier', href: 'https://prettier.io/' },
  {
    type: 'Edytor AI',
    name: 'Opencode (MiMo V2.5 Free)',
    href: 'https://opencode.ai/',
  },
]
---

<Layout>
  <section container mx-auto mt-12>
    <header text-center text-4xl font-semibold mb-6>
      <h1>O witrynie</h1>
    </header>
    <article>
      <header text-2xl mb-4>
        <h2>Stack technologiczny</h2>
      </header>
      <table>
        {
          stack.map((item) => (
            <tr>
              <td pr-4 py-1>
                {item.type}:
              </td>
              <td>
                <a
                  link:text-blue-500
                  visited:text-purple-500
                  hover-visited:border-b="2px solid purple-500"
                  hover:border-b="2px solid blue-500"
                  border-b="2px solid transparent"
                  href={item.href}
                  target="_blank"
                >
                  {item.name}
                </a>
              </td>
            </tr>
          ))
        }
      </table>
    </article>
  </section>
</Layout>

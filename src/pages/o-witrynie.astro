---
import Layout from '@layouts/Layout.astro'
import eslintConfig from '@root/eslint.config?raw'
import prettierConfig from '@root/.prettierrc?raw'
import tsconfig from '@root/tsconfig.json?raw'
import packageJson from '@root/package.json?raw'
import astroConfig from '@root/astro.config.mjs?raw'
import mise from '@root/mise.toml?raw'
import globalCss from '@root/src/styles/global.css?raw'
import type { CodeLanguage } from 'astro'
import { Code } from 'astro:components'

interface StackItem {
  type: string
  name: string
  href: string
}

const stack = [
  { type: 'Framework', name: 'Astro (SSG)', href: 'https://astro.build/' },
  { type: 'Silnik styli', name: 'Tailwind CSS', href: 'https://tailwindcss.com/' },
  {
    type: 'Skrypty',
    name: 'TypeScript',
    href: 'https://www.typescriptlang.org/',
  },
  { type: 'Menadżer pakietów', name: 'Bun', href: 'https://bun.com/' },
  { type: 'Linter', name: 'ESLint', href: 'https://eslint.org/' },
  { type: 'Formatter', name: 'Prettier', href: 'https://prettier.io/' },
  {
    type: 'Edytor AI',
    name: 'Opencode (MiMo V2.5 Free)',
    href: 'https://opencode.ai/',
  },
] as const satisfies StackItem[]

interface ConfigItem {
  name: string
  code: string
  type: CodeLanguage
}

const configs = [
  {
    name: 'astro.config.mjs',
    code: astroConfig,
    type: 'js',
  },
  {
    name: 'eslint.config.js',
    code: eslintConfig,
    type: 'ts',
  },
  {
    name: '.prettierrc',
    code: prettierConfig,
    type: 'json',
  },
  {
    name: 'tsconfig.json',
    code: tsconfig,
    type: 'jsonc',
  },
  {
    name: 'package.json',
    code: packageJson,
    type: 'json',
  },
  {
    name: 'src/styles/global.css',
    code: globalCss,
    type: 'css',
  },
  {
    name: 'mise.toml',
    code: mise,
    type: 'toml',
  },
] as const satisfies ConfigItem[]
---

<Layout parentHref="/o-witrynie">
  <section>
    <header class="text-center text-4xl font-semibold mb-6">
      <h1>O witrynie</h1>
    </header>
    <article>
      <header class="text-2xl mb-4">
        <h2>Stack technologiczny</h2>
      </header>
      <table>
        {
          stack.map((item) => (
            <tr>
              <td class="pr-4 py-1">
                {item.type}:
              </td>
              <td>
                <a
                  class="text-blue-500 visited:text-purple-500 hover:visited:border-b-2 hover:visited:border-solid hover:visited:border-purple-500 hover:border-b-2 hover:border-solid hover:border-blue-500 border-b-2 border-solid border-transparent"
                  href={item.href}
                  target="_blank"
                >
                  {item.name}
                </a>
              </td>
            </tr>
          ))
        }
      </table>
    </article>
    <article class="mt-4">
      <header class="text-2xl mb-4">
        <h2>Konfiguracje</h2>
      </header>
      <div class="flex flex-col gap-2">
        {
          configs.map((item) => (
            <div class="overflow-hidden min-h-0">
              <input
                type="checkbox"
                id={`toggle-${item.name}`}
                hidden
                class="peer"
              />
              <label
                for={`toggle-${item.name}`}
                class="border-2 border-black flex flex-row items-center"
              >
                <p class="p-2 flex-1 border-r-2 border-black">
                  {item.name}
                </p>
                <span class="p-2 px-4 rotate-90 transition-transform">
                  &rangle;
                </span>
              </label>

              <div
                class="grid overflow-hidden duration-400 ease-in-out grid-rows-[0fr] transition-[grid-template-rows] peer-checked:grid-rows-[1fr]"
              >
                <div class="min-h-0">
                  <Code
                    class="p-4"
                    data-name={item.name}
                    code={item.code}
                    lang={item.type}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </article>
  </section>
</Layout>

<style>
  input.peer:checked + label > span {
    scale: -1 -1;
  }
</style>

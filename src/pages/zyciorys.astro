---
import Layout from '../layouts/Layout.astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'

type LifeStageEntry = CollectionEntry<'lifeStages'>

interface IncludedStage {
  entry: LifeStageEntry
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  Content: any
  top?: string
  height?: string
}

interface StageWithContent {
  entry: LifeStageEntry
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  Content: any
  included: IncludedStage[]
  color: string
  top: string
  height: string
  startDate: Temporal.PlainDate
  endDate: Temporal.PlainDate
}

const allStages = await getCollection('lifeStages')

const parents = allStages
  .filter((s: LifeStageEntry) => !s.data.parent)
  .sort((a: LifeStageEntry, b: LifeStageEntry) => a.data.order - b.data.order)

const children = allStages
  .filter((s: LifeStageEntry) => s.data.parent)
  .sort((a: LifeStageEntry, b: LifeStageEntry) => a.data.order - b.data.order)

const stagesWithContent: Array<{
  entry: LifeStageEntry
  Content: any // eslint-disable-line @typescript-eslint/no-explicit-any
  included: IncludedStage[]
}> = await Promise.all(
  parents.map(async (parent: LifeStageEntry) => {
    const { Content } = await render(parent)
    const included = await Promise.all(
      children
        .filter((c: LifeStageEntry) => c.data.parent === parent.id)
        .map(async (c: LifeStageEntry) => {
          const { Content: IncContent } = await render(c)
          return { entry: c, Content: IncContent }
        }),
    )
    return { entry: parent, Content, included }
  }),
)

const MIN_HEIGHT_PER_YEAR = 100

const allDates = stagesWithContent.flatMap((s) => [
  Temporal.PlainDate.from(s.entry.data.startDate),
  Temporal.PlainDate.from(s.entry.data.endDate),
  ...s.included
    .map((inc: IncludedStage) => [
      Temporal.PlainDate.from(inc.entry.data.startDate),
      Temporal.PlainDate.from(inc.entry.data.endDate),
    ])
    .flat(),
])
const globalStart = allDates.reduce((min, d) =>
  Temporal.PlainDate.compare(min, d) < 0 ? min : d,
)
const globalEnd = allDates.reduce((max, d) =>
  Temporal.PlainDate.compare(max, d) > 0 ? max : d,
)

const months = [
  'Sty',
  'Lut',
  'Mar',
  'Kwi',
  'Maj',
  'Cze',
  'Lip',
  'Sie',
  'Wrz',
  'Paź',
  'Lis',
  'Gru',
]

function formatDate(date: Temporal.PlainDate): string {
  return `${months[date.month - 1]} ${date.year.toString()}`
}

const timelineStart = Temporal.PlainDate.from({
  day: 1,
  month: 1,
  year: globalStart.year,
})
const timelineEnd = Temporal.PlainDate.from({
  day: 1,
  month: 1,
  year: globalEnd.year + 1,
})

const totalDays = timelineStart.until(timelineEnd, { smallestUnit: 'day' }).days
const heightPerDay = Math.max(MIN_HEIGHT_PER_YEAR / 365.25, 0.75)
const timelineHeight = totalDays * heightPerDay

function dateToPercent(date: Temporal.PlainDate): number {
  const offset =
    timelineStart.until(date, { smallestUnit: 'day' }).days * heightPerDay
  return (offset / timelineHeight) * 100
}

const stagesWithStyles = stagesWithContent.map((stage) => {
  const startDate = Temporal.PlainDate.from(stage.entry.data.startDate)
  const endDate = Temporal.PlainDate.from(stage.entry.data.endDate)
  const eventTop = dateToPercent(startDate)
  const eventHeight = dateToPercent(endDate) - eventTop
  const eventDurationDays = startDate.until(endDate, {
    smallestUnit: 'day',
  }).days

  const included = stage.included.map((inc: IncludedStage) => {
    const incStart = Temporal.PlainDate.from(inc.entry.data.startDate)
    const incEnd = Temporal.PlainDate.from(inc.entry.data.endDate)
    const incTopDays = startDate.until(incStart, { smallestUnit: 'day' }).days
    const incDurationDays = incStart.until(incEnd, { smallestUnit: 'day' }).days
    return {
      ...inc,
      top: `${((incTopDays / eventDurationDays) * 100).toString()}%`,
      height: `${((incDurationDays / eventDurationDays) * 100).toString()}%`,
    }
  })

  return {
    ...stage,
    color: stage.entry.data.color,
    top: `${eventTop.toString()}%`,
    height: `${eventHeight.toString()}%`,
    startDate,
    endDate,
    included,
  }
})

const totalYears = timelineStart.until(timelineEnd, {
  smallestUnit: 'year',
  largestUnit: 'year',
}).years

const yearTicks = Array.from({ length: totalYears + 1 }, (_, i) => {
  const year = timelineStart.add({ years: i }).year
  const date = Temporal.PlainDate.from({ day: 1, month: 1, year })
  return { year, top: `${dateToPercent(date).toString()}%` }
})
---

<Layout>
  <section>
    <header text-center text-4xl font-semibold mb-6>
      <h1>Życiorys</h1>
    </header>

    <div max-w-900px px-4>
      <div relative ml-160px style={`height: ${timelineHeight.toString()}px`}>
        <span
          id="divider"
          absolute
          border-l="3px solid #e5e7eb"
          left-0
          h-full
          class="-translate-x-1/2"
        >
        </span>

        {
          yearTicks.map((tick) => (
            <div
              absolute
              flex
              items-center
              h-0
              style={`top: ${tick.top}; left: -160px; width: 150px`}
            >
              <span
                text-right
                text-sm
                text-gray-400
                tabular-nums
                select-none
                flex-none
                style="width: 140px"
              >
                {tick.year}
              </span>
              <div flex-1 border-t="1px dashed #e5e7eb" ml-12px />
            </div>
          ))
        }

        {
          stagesWithStyles.map((stage) => (
            <div
              absolute
              style={`top: ${stage.top}; height: ${stage.height}; left: -1.75px; right: 0; border-left: 4px solid ${stage.color}; border-radius: 6px`}
            >
              <div
                absolute
                rounded-full
                border="3px solid white"
                class="-translate-x-[calc(50%+1.75px)] size-[12px]"
                style={`left: 0; top: 0; background-color: ${stage.color}; box-shadow: 0 0 0 2px ${stage.color}`}
              />
              <div
                absolute
                rounded-full
                border="3px solid white"
                class="-translate-x-[calc(50%+1.75px)] size-[12px]"
                style={`left: 0; bottom: 0; background-color: ${stage.color}; box-shadow: 0 0 0 2px ${stage.color}`}
              />

              <span
                absolute
                text-xs
                font-semibold
                whitespace-nowrap
                style={`left: -75px; top: 0; color: ${stage.color}`}
              >
                {formatDate(stage.startDate)}
              </span>
              <span
                absolute
                text-xs
                font-semibold
                whitespace-nowrap
                style={`left: -75px; bottom: 0; color: ${stage.color}`}
              >
                {formatDate(stage.endDate)}
              </span>

              <div
                ml-20px
                bg-white
                rounded-md
                shadow-sm
                p-2
                flex
                flex-col
                gap-1
                style={`border-left: 3px solid ${stage.color}`}
              >
                <span font-semibold text-sm text-gray-800>
                  {stage.entry.data.label}
                </span>
                <div text-xs text-gray-600 leading-relaxed>
                  <stage.Content />
                </div>
                <span text-xs text-gray-500 tabular-nums>
                  {stage.entry.data.startDate} — {stage.entry.data.endDate}
                </span>
              </div>

              {stage.included.map((inc) => (
                <div
                  absolute
                  style={`top: ${inc.top}; height: ${inc.height}; left: 3px; right: 8px;`}
                >
                  <div
                    ml-12px
                    p-1
                    rounded
                    style={`background: rgba(255,255,255,0.9); border-left: 2px solid ${stage.color}; max-width: calc(100% - 16px)`}
                  >
                    <span font-medium text-xs text-gray-700>
                      {inc.entry.data.label}
                    </span>
                    <span text-xs text-gray-500 tabular-nums block>
                      {inc.entry.data.startDate} — {inc.entry.data.endDate}
                    </span>
                    <div text-xs text-gray-600 leading-relaxed>
                      <inc.Content />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

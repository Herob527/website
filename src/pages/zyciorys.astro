---
import Layout from '../layouts/Layout.astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import type { AstroComponentFactory } from 'astro/runtime/server/render/astro/factory.js'

type LifeStageEntry = CollectionEntry<'lifeStages'>

interface IncludedStage {
  entry: LifeStageEntry
  Content: AstroComponentFactory
}

interface StageWithContent {
  entry: LifeStageEntry
  Content: AstroComponentFactory
  included: IncludedStage[]
}

const allStages = await getCollection('lifeStages')

const parents = allStages
  .filter((s) => !s.data.parent)
  .sort((a, b) => a.data.order - b.data.order)

const children = allStages
  .filter((s) => s.data.parent)
  .sort((a, b) => a.data.order - b.data.order)

const stagesWithContent = await Promise.all(
  parents.map(async (parent) => {
    const { Content } = await render(parent)
    const included = await Promise.all(
      children
        .filter((c) => c.data.parent === parent.id)
        .map(async (c) => {
          const { Content: IncContent } = await render(c)
          return { entry: c, Content: IncContent }
        }),
    )
    return { entry: parent, Content, included }
  }),
)

const months = [
  'Sty',
  'Lut',
  'Mar',
  'Kwi',
  'Maj',
  'Cze',
  'Lip',
  'Sie',
  'Wrz',
  'Paź',
  'Lis',
  'Gru',
]

const formatDate = (date: Temporal.PlainDate) => {
  return `${months[date.month - 1]} ${date.year.toString()}`
}

const sorted = stagesWithContent
  .map((s: StageWithContent) => ({
    ...s,
    startDate: Temporal.PlainDate.from(s.entry.data.startDate),
    endDate: Temporal.PlainDate.from(s.entry.data.endDate),
    color: s.entry.data.color,
  }))
  .sort((a, b) => Temporal.PlainDate.compare(a.startDate, b.startDate))
---

<Layout>
  <section>
    <header text-center text-4xl font-semibold mb-6>
      <h1>Życiorys</h1>
    </header>

    <div max-w-900px mx-auto px-4>
      <div relative border-l="2px solid #e5e7eb" ml-6>
        {
          sorted.map((stage) => (
            <div mb-12 pl-8>
              <span text-xs font-semibold text-gray-400 tabular-nums>
                {formatDate(stage.startDate)} — {formatDate(stage.endDate)}
              </span>

              <div
                mt-2
                bg-white
                shadow-sm
                p-3
                style={`border-left: 3px solid ${stage.color}`}
              >
                <span font-semibold text-sm text-gray-800>
                  {stage.entry.data.label}
                </span>
                <div
                  text-xs
                  text-gray-600
                  leading-relaxed
                  mt-1
                  class="timeline-content"
                >
                  <stage.Content />
                </div>
                {stage.included.map((inc: IncludedStage) => (
                  <div
                    p-2
                    mt-2
                    style={`background: rgba(245,245,245,0.9); border-left: 2px solid ${stage.color}`}
                  >
                    <span font-medium text-xs text-gray-700>
                      {inc.entry.data.label}
                    </span>
                    <span text-xs text-gray-500 tabular-nums block>
                      {inc.entry.data.startDate} — {inc.entry.data.endDate}
                    </span>
                    <div text-xs text-gray-600 leading-relaxed mt-1>
                      <inc.Content />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  a {
    color: #3b82f6 !important;
    text-decoration: underline !important;
  }
</style>

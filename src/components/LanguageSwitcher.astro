---
import { DEFAULT_LOCALE } from '../i18n'

const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const { t } = Astro.locals

const base = import.meta.env.BASE_URL
const pathname = Astro.url.pathname

let relativePath = base !== '/' ? pathname.replace(base, '') : pathname
if (relativePath.startsWith(`/${currentLocale}`)) {
  relativePath = relativePath.slice(`/${currentLocale}`.length) || '/'
}

const plHref =
  DEFAULT_LOCALE === 'pl'
    ? `${base}${relativePath}`
    : `${base}/pl${relativePath}`

const enHref = `${base}/en${relativePath}`

const currentIsPl = currentLocale === 'pl'
---

<span class="inline-flex gap-1 items-center">
  {
    currentIsPl ? (
      <span class="w-6 h-4.5 icon-[flag--pl-4x3]" />
    ) : (
      <a
        href={plHref.replace('//', '/')}
        aria-label={t('langSwitcher.toPl')}
        class="w-6 h-4.5 icon-[flag--pl-4x3] opacity-40 hover:opacity-100 transition-opacity"
      />
    )
  }
  <span class="text-gray-300">|</span>
  {
    !currentIsPl ? (
      <span class="w-6 h-4.5 icon-[flag--us-4x3]" />
    ) : (
      <a
        href={enHref.replace('//', '/')}
        aria-label={t('langSwitcher.toEn')}
        class="w-6 h-4.5 icon-[flag--us-4x3] opacity-40 hover:opacity-100 transition-opacity"
      />
    )
  }
</span>

---
import { locales, DEFAULT_LOCALE } from '../i18n'

const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const alternateLocale =
  locales.find((l) => l !== currentLocale) ?? DEFAULT_LOCALE

const base = import.meta.env.BASE_URL
const pathname = Astro.url.pathname

let relativePath = base !== '/' ? pathname.replace(base, '') : pathname
if (relativePath.startsWith(`/${currentLocale}`)) {
  relativePath = relativePath.slice(`/${currentLocale}`.length) || '/'
}

const href =
  alternateLocale === DEFAULT_LOCALE
    ? `${base}${relativePath}`
    : `${base}/${alternateLocale}${relativePath}`

const { t } = Astro.locals

const currentIsPl = currentLocale === 'pl'
const ariaLabel = currentIsPl ? t('langSwitcher.toEn') : t('langSwitcher.toPl')
---

<span class="inline-flex gap-1 items-center">
  <span
    class:list={[
      'w-6 h-4.5',
      {
        'icon-[flag--pl-4x3]': currentIsPl,
        'icon-[flag--us-4x3]': !currentIsPl,
      },
    ]}></span>
  <span class="text-gray-300">|</span>
  <a
    href={href.replace('//', '/')}
    aria-label={ariaLabel}
    class:list={[
      'w-6 h-4.5 opacity-40 hover:opacity-100 transition-opacity',
      {
        'icon-[flag--us-4x3]': currentIsPl,
        'icon-[flag--pl-4x3]': !currentIsPl,
      },
    ]}></a>
</span>
